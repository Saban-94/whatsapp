rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && (
        request.auth.uid == userId || 
        (request.auth.token.email != null && request.auth.token.email.replace('@gmail.com', '') == userId)
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation for JoniUser
    function isValidJoniUser(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 128
        && (data.status == null || (data.status is string && data.status.size() <= 256))
        && (data.avatar == null || (data.avatar is string && data.avatar.size() <= 1048576)) 
        && (data.phoneNumber == null || (data.phoneNumber is string && data.phoneNumber.size() <= 32))
        && (data.updatedAt == null || (data.updatedAt is string && data.updatedAt.size() <= 64));
    }

    // Validation for JoniOutbox
    function isValidJoniOutbox(data) {
      return data.phoneNumber is string && data.phoneNumber.size() > 0 && data.phoneNumber.size() <= 32
        && data.text is string && data.text.size() > 0 && data.text.size() <= 1048576
        && data.mediaType is string && data.mediaType.size() > 0 && data.mediaType.size() <= 64
        && (data.mediaUrl == null || (data.mediaUrl is string && data.mediaUrl.size() <= 2048))
        && data.timestamp is string && data.timestamp.size() <= 64
        && data.source is string && data.source.size() <= 128
        && data.status is string && data.status.size() <= 64;
    }

    // Users Collection rules
    match /joni_users/{userId} {
      allow read: if isVerified();
      allow create, update: if isVerified() && isOwner(userId) && isValidJoniUser(incoming());
      allow delete: if false;
    }

    // Outbox Collection rules (Write-Only queue)
    match /joni_outbox/{msgId} {
      allow read: if isVerified();
      allow create: if isVerified() && isValidJoniOutbox(incoming());
      allow update, delete: if false;
    }

  }
}
